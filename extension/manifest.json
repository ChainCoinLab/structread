{
  "manifest_version": 3,
  "name": "StructRead",
  "version": "1.0.0",
  "description": "Understand English with AI-powered sentence parsing and structure visualization.",
  "permissions": ["activeTab", "contextMenus", "storage", "scripting"],
  "host_permissions": ["http://127.0.0.1:8082/*"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
