{
  "manifest_version": 3,
  "name": "English Sentence Analyzer",
  "version": "1.0.0",
  "description": "Analyze English sentences — highlight grammar components and explain structure.",
  "permissions": ["activeTab", "contextMenus", "storage"],
  "host_permissions": ["http://127.0.0.1:8082/*"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
